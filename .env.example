ENV=local

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=prepareup
POSTGRES_USER=prepareup
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Computed from above — keep in sync
DATABASE_URL=postgresql+psycopg://prepareup:CHANGE_ME_strong_db_password@db:5432/prepareup

CORS_ORIGINS=http://localhost:3000

# ── pgAdmin (local dev only) ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@prepareup.com
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-REPLACE_WITH_REAL_KEY
OPENAI_MODEL=gpt-4o-mini
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1

# ── Discord OAuth + Bot ───────────────────────────────────────────────────────
DISCORD_CLIENT_ID=YOUR_DISCORD_APP_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_APP_CLIENT_SECRET
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_BOT_PERMISSIONS=66560

# ── App / JWT ─────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000
APP_SECRET=CHANGE_ME_random_32_char_secret
JWT_SECRET=CHANGE_ME_random_64_char_secret
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# Set to true in production (requires HTTPS)
COOKIE_SECURE=false

# ── Google OAuth ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
